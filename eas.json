{
  "cli": {
    "version": ">= 16.24.1",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "SKIP_IOS_FRAMEWORK_DOWNLOAD": "1"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "SKIP_IOS_FRAMEWORK_DOWNLOAD": "1"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "SKIP_IOS_FRAMEWORK_DOWNLOAD": "1"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
